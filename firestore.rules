rules_version = '2';

// Deploy: `firebase deploy --only firestore:rules` (Firebase CLI, project selected).
// Course epic: gate destructive course ops with request.auth.token.admin == true.

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
