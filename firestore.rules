rules_version = '2';

// Deploy: `firebase deploy --only firestore:rules,firestore:indexes` (Firebase CLI, project selected).
// Course epic (#3): authenticated reads; users create courses/templates; admins gate canonical updates/deletes.
// Scoring epic (#4): rounds readable per visibility + participants; scores mutable by owner + participants.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;
    }

    function validVisibility(v) {
      return v == 'public' || v == 'private' || v == 'unlisted';
    }

    function validCourseSource(source) {
      return source == 'saved' || source == 'fresh';
    }

    function validPromotionStatus(status) {
      return status == 'none'
        || status == 'pending'
        || status == 'created'
        || status == 'failed';
    }

    function validRoundPromotionShape(data) {
      return data.coursePromotion is map
        && validPromotionStatus(data.coursePromotion.status);
    }

    function freshDraftPresentWhenNeeded(data) {
      return data.courseSource != 'fresh'
        || (
          data.courseDraft is map
          && data.courseDraft.name is string
          && data.courseDraft.holes is list
        );
    }

    function isRoundParticipant(data) {
      return signedIn()
        && data.participantIds is list
        && request.auth.uid in data.participantIds;
    }

    function isRoundOwner(data) {
      return signedIn() && request.auth.uid == data.ownerId;
    }

    function roundImmutableFieldsUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.courseId == resource.data.courseId
        && request.resource.data.templateId == resource.data.templateId
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function participantIdsChangeAllowed() {
      return request.resource.data.participantIds == resource.data.participantIds
        || isRoundOwner(resource.data)
        || isAdmin();
    }

    function anonymousParticipantsChangeAllowed() {
      return request.resource.data.anonymousParticipants == resource.data.anonymousParticipants
        || isRoundOwner(resource.data)
        || isAdmin();
    }

    function validAnonymousParticipantsShape(data) {
      return !data.keys().hasAny(['anonymousParticipants'])
        || data.anonymousParticipants is list;
    }

    function visibilityChangeAllowed() {
      return request.resource.data.visibility == resource.data.visibility
        || isRoundOwner(resource.data);
    }

    function courseOriginFieldsAllowed() {
      return request.resource.data.courseSource == resource.data.courseSource
        && (
          request.resource.data.courseSource != 'fresh'
          ? request.resource.data.courseDraft == resource.data.courseDraft
          : (
            request.resource.data.courseDraft is map
            && request.resource.data.courseDraft.name is string
            && request.resource.data.courseDraft.holes is list
          )
        );
    }

    function promotionChangeAllowed() {
      return request.resource.data.coursePromotion == resource.data.coursePromotion
        || isRoundOwner(resource.data);
    }

    function validFollowEdge(data) {
      return data.keys().hasOnly(['followerUid', 'followeeUid', 'createdAt'])
        && data.followerUid is string
        && data.followeeUid is string
        && data.followerUid != data.followeeUid;
    }

    function isFollowOwner(data) {
      return signedIn() && data.followerUid == request.auth.uid;
    }

    function validPublicUserProfile(data) {
      return data.keys().hasOnly(['displayName', 'photoUrl', 'favoriteCourseIds', 'admin', 'createdAt'])
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 80
        && (data.photoUrl == null || data.photoUrl is string)
        && (!data.keys().hasAny(['favoriteCourseIds']) || data.favoriteCourseIds is list)
        && (!data.keys().hasAny(['admin']) || data.admin is bool)
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get, list: if signedIn();

      allow create: if signedIn()
        && request.auth.uid == userId
        && validPublicUserProfile(request.resource.data)
        && request.resource.data.admin != true;

      allow update: if signedIn()
        && request.auth.uid == userId
        && validPublicUserProfile(request.resource.data)
        && request.resource.data.photoUrl == resource.data.photoUrl
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.admin == resource.data.admin;

      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /courses/{courseId} {
      allow get, list: if signedIn();

      allow create: if signedIn()
        && request.resource.data.keys().hasAll([
          'name',
          'slug',
          'createdBy',
          'createdAt',
        ])
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.slug is string;

      // Canonical fields live on the course doc; only admins may update or delete.
      allow update, delete: if isAdmin();

      match /templates/{templateId} {
        allow get, list: if signedIn();

        allow create: if signedIn()
          && request.resource.data.keys().hasAll([
            'label',
            'holes',
            'source',
            'createdBy',
            'createdAt',
          ])
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.label is string
          && request.resource.data.holes is list
          && request.resource.data.source in ['official', 'crowd', 'derived'];

        allow update: if signedIn() && (
          isAdmin() || resource.data.createdBy == request.auth.uid
        );

        allow delete: if signedIn() && (
          isAdmin() || resource.data.createdBy == request.auth.uid
        );
      }
    }

    match /rounds/{roundId} {
      // Allow authenticated clients to read rounds; write paths still enforce ownership/participant checks.
      allow get, list: if signedIn();

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.participantIds is list
        && request.auth.uid in request.resource.data.participantIds
        && validVisibility(request.resource.data.visibility)
        && validCourseSource(request.resource.data.courseSource)
        && validRoundPromotionShape(request.resource.data)
        && freshDraftPresentWhenNeeded(request.resource.data)
        && validAnonymousParticipantsShape(request.resource.data)
        && request.resource.data.keys().hasAll([
          'ownerId',
          'participantIds',
          'courseId',
          'templateId',
          'courseSource',
          'courseDraft',
          'coursePromotion',
          'visibility',
          'startedAt',
          'completedAt',
          'holeScores',
          'createdAt',
          'updatedAt',
        ]);

      allow update: if (isRoundOwner(resource.data) || isRoundParticipant(resource.data) || isAdmin())
        && roundImmutableFieldsUnchanged()
        && participantIdsChangeAllowed()
        && anonymousParticipantsChangeAllowed()
        && visibilityChangeAllowed()
        && courseOriginFieldsAllowed()
        && promotionChangeAllowed()
        && validVisibility(request.resource.data.visibility)
        && validCourseSource(request.resource.data.courseSource)
        && validRoundPromotionShape(request.resource.data)
        && freshDraftPresentWhenNeeded(request.resource.data)
        && validAnonymousParticipantsShape(request.resource.data);

      allow delete: if isRoundOwner(resource.data) || isAdmin();
    }

    match /follows/{edgeId} {
      allow get, list: if signedIn();

      allow create: if signedIn()
        && validFollowEdge(request.resource.data)
        && request.resource.data.followerUid == request.auth.uid;

      allow update: if false;

      allow delete: if isFollowOwner(resource.data);
    }
  }
}
