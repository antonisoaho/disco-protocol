rules_version = '2';

// Deploy: `firebase deploy --only firestore:rules,firestore:indexes` (Firebase CLI, project selected).
// Course epic (#3): authenticated reads; users create courses/templates; admins gate canonical updates/deletes.
// Scoring epic (#4): rounds readable per visibility + participants; scores mutable by owner + participants.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function validVisibility(v) {
      return v == 'public' || v == 'private' || v == 'unlisted';
    }

    function isRoundParticipant(data) {
      return signedIn()
        && data.participantIds is list
        && request.auth.uid in data.participantIds;
    }

    function isRoundOwner(data) {
      return signedIn() && request.auth.uid == data.ownerId;
    }

    function roundImmutableFieldsUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.courseId == resource.data.courseId
        && request.resource.data.templateId == resource.data.templateId
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function participantIdsChangeAllowed() {
      return request.resource.data.participantIds == resource.data.participantIds
        || isRoundOwner(resource.data);
    }

    function visibilityChangeAllowed() {
      return request.resource.data.visibility == resource.data.visibility
        || isRoundOwner(resource.data);
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /courses/{courseId} {
      allow get, list: if signedIn();

      allow create: if signedIn()
        && request.resource.data.keys().hasAll([
          'name',
          'slug',
          'createdBy',
          'createdAt',
        ])
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.slug is string;

      // Canonical fields live on the course doc; only admins may update or delete.
      allow update, delete: if isAdmin();

      match /templates/{templateId} {
        allow get, list: if signedIn();

        allow create: if signedIn()
          && request.resource.data.keys().hasAll([
            'label',
            'holes',
            'source',
            'createdBy',
            'createdAt',
          ])
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.label is string
          && request.resource.data.holes is list
          && request.resource.data.source in ['official', 'crowd', 'derived'];

        allow update: if signedIn() && (
          isAdmin() || resource.data.createdBy == request.auth.uid
        );

        allow delete: if signedIn() && (
          isAdmin() || resource.data.createdBy == request.auth.uid
        );
      }
    }

    match /rounds/{roundId} {
      // Allow authenticated clients to read rounds; write paths still enforce ownership/participant checks.
      allow get, list: if signedIn();

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.participantIds is list
        && request.auth.uid in request.resource.data.participantIds
        && validVisibility(request.resource.data.visibility)
        && request.resource.data.keys().hasAll([
          'ownerId',
          'participantIds',
          'courseId',
          'templateId',
          'visibility',
          'startedAt',
          'completedAt',
          'holeScores',
          'createdAt',
          'updatedAt',
        ]);

      allow update: if (isRoundOwner(resource.data) || isRoundParticipant(resource.data))
        && roundImmutableFieldsUnchanged()
        && participantIdsChangeAllowed()
        && visibilityChangeAllowed()
        && validVisibility(request.resource.data.visibility);

      allow delete: if false;
    }
  }
}
