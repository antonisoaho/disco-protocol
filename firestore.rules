rules_version = '2';

// Deploy: `firebase deploy --only firestore:rules,firestore:indexes` (Firebase CLI, project selected).
// Course epic (#3): client writes to courses are admin-only; reads are authenticated.
// Scoring epic (#4): rounds readable per visibility + participants; scores mutable by owner + participants.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function validVisibility(v) {
      return v == 'public' || v == 'private' || v == 'unlisted';
    }

    function isRoundParticipant(data) {
      return isSignedIn() && request.auth.uid in data.participantIds;
    }

    function isRoundOwner(data) {
      return isSignedIn() && request.auth.uid == data.ownerId;
    }

    function canReadRound(data) {
      return isRoundParticipant(data)
        || (isSignedIn() && data.visibility == 'public');
    }

    function roundImmutableFieldsUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.courseId == resource.data.courseId
        && request.resource.data.templateId == resource.data.templateId
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function participantIdsChangeAllowed() {
      return request.resource.data.participantIds == resource.data.participantIds
        || isRoundOwner(resource.data);
    }

    function visibilityChangeAllowed() {
      return request.resource.data.visibility == resource.data.visibility
        || isRoundOwner(resource.data);
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /templates/{templateId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    match /rounds/{roundId} {
      allow read: if canReadRound(resource.data);

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.participantIds
        && validVisibility(request.resource.data.visibility)
        && request.resource.data.keys().hasAll([
          'ownerId',
          'participantIds',
          'courseId',
          'templateId',
          'visibility',
          'startedAt',
          'completedAt',
          'holeScores',
          'createdAt',
          'updatedAt',
        ]);

      allow update: if (isRoundOwner(resource.data) || isRoundParticipant(resource.data))
        && roundImmutableFieldsUnchanged()
        && participantIdsChangeAllowed()
        && visibilityChangeAllowed()
        && validVisibility(request.resource.data.visibility);

      allow delete: if false;
    }
  }
}
