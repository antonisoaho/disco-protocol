# Firebase web app config (Project settings → Your apps → SDK setup and configuration).
# Copy this file to .env.local and fill in values. Do not commit .env.local.
# Wrong or placeholder apiKey → Identity Toolkit "API_KEY_INVALID" at runtime (not at `npm run build`).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firestore IndexedDB persistence (optional). Use `true` after Auth is enabled; default/unset uses memory cache.
# VITE_FIRESTORE_PERSISTENCE=true
